{
    "name": "dinubo/laravel-mailer",
    "description": "Schedule and send segmented Laravel newsletters with per-recipient placeholders, open/click tracking, unsubscribe handling, provider webhooks (Postmark, Resend), and a built-in admin UI.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Petros Petrou",
            "email": "petros@dinubo.com",
            "homepage": "https://dinubo.com"
        }
    ],
    "homepage": "https://github.com/dinubo/laravel-mailer",
    "support": {
        "issues": "https://github.com/dinubo/laravel-mailer/issues",
        "source": "https://github.com/dinubo/laravel-mailer"
    },
    "keywords": ["laravel", "newsletter", "mailer", "email", "mailing-list", "email-tracking", "unsubscribe", "postmark", "resend"],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Dinubo\\Mailer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dinubo\\Mailer\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dinubo\\Mailer\\MailerServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
